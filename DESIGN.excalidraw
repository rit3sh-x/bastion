    {
      "type": "text",
      "id": "s3_note_spend",
      "x": 580,
      "y": 1905,
      "width": 470,
      "height": 90,
      "text": "two-phase spend: snapshot the balance BEFORE the CPI, re-read AFTER, charge the delta. Enforces \"spend ≤ X per window\" from the effect on accounts — never trusting the instruction bytes.",
      "originalText": "two-phase spend: snapshot the balance BEFORE the CPI, re-read AFTER, charge the delta. Enforces \"spend ≤ X per window\" from the effect on accounts — never trusting the instruction bytes.",
