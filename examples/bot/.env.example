# Copy to .env and fill in.
# `pnpm -F @examples/bot dev` loads this automatically (tsx --env-file).

# ── Groq ──
# API key for the LLM. Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Model — must support tool/function calling. Default: llama-3.3-70b-versatile
# MODEL=llama-3.3-70b-versatile

# ── Solana RPC ──
# Devnet free, no key required. For mainnet plug in Helius/QuickNode/etc.
RPC_URL=https://api.devnet.solana.com
# WebSocket URL. Optional — derived from RPC_URL if unset. For Surfpool set it
# explicitly (its RPC is :8899 but the WS is on :8900):
# WS_URL=ws://127.0.0.1:8900

# ── Wallet ──
# Base58 secret-key (64-byte) of the OWNER wallet. THROWAWAY KEYS ONLY for
# demo. Generate with: solana-keygen new --no-bip39-passphrase -o /tmp/k.json
# then base58-encode the 64-byte secretKey array.
# If unset, the bot generates a fresh keypair and warns (it'll have 0 SOL).
OWNER_SECRET=

# Base58 secret-key (64-byte) of the SESSION key. It derives the session PDA
# AND the delegate (spend pool) PDA — so a FIXED value gives a STABLE delegate
# you fund once and reuse across runs. Generate the same way as OWNER_SECRET.
# If unset, an ephemeral session key is used (its delegate changes every run,
# so you can't pre-fund it).
SESSION_SECRET=

# ── Allowance / token mode (recommended — "use my wallet") ──
# Set MINT to trade in ALLOWANCE mode: the agent spends the owner's SPL tokens
# straight from the owner's ATA after a one-time owner `approve` — funds NEVER
# move to a separate delegate account. Unset → native-SOL VAULT mode (the agent
# spends a delegate PDA you pre-fund).
# MINT=<spl-mint-address>
# Mint decimals (USDC=6). Default: 6.
# DECIMALS=6
# Display label for the spend asset. Default: TOKEN.
# TOKEN_SYMBOL=USDC
# Tier-1 hard ceiling: whole tokens the one-time approve grants the delegate.
# The on-chain SPL token program enforces this; Bastion's per-trade/lifetime
# caps (tier-2) are finer and windowed. Default: 1000.
# ALLOWANCE=1000

# ── Demo controls ──
# Max tool steps agent may take per user turn. Default: 8.
# MAX_STEPS=8
# Destination for swap/buy. VAULT mode: any pubkey. ALLOWANCE (token) mode: the
# RECIPIENT WALLET — its ATA for MINT is derived (and must exist; the demo
# creates it). Required for token spends.
# SWAP_DEST=<recipient-wallet-address>
# Dry-run: skip Groq + chain, just validate policy construction (CI smoke test).
# DRY_RUN=1
